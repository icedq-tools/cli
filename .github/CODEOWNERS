# Code owners for @icedq/cli
#
# Review from a listed owner is required to merge changes to these paths
# (enforced once "Require review from Code Owners" is enabled in branch
# protection). This protects the release pipeline from unreviewed changes.
#
# Note: @icedq-tools/maintainers must have write access to this repo, or
#       GitHub ignores it as a code owner.

# The release/CI pipeline and ownership file itself
/.github/workflows/   @icedq-tools/maintainers
/.github/CODEOWNERS    @icedq-tools/maintainers

# Packaging and licensing
/package.json   @icedq-tools/maintainers
/LICENSE        @icedq-tools/maintainers
/NOTICE         @icedq-tools/maintainers
